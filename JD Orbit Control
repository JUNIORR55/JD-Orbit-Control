local cmds = {"offset", "speed", "rot", "mode", "target", "unorbit", "equip", "unequip", "stop", "lerp", "help"}

local cmdDocs = {
    offset = "offset [num] - Sets radius distance",
    speed = "speed [num] - Sets orbit speed",
    rot = "rot [num] - Sets tool spinning speed",
    mode = "mode [num] - Changes orbit pattern (1-20+)",
    target = "target [name] - Orbits a specific player",
    unorbit = "unorbit - Returns orbit to yourself",
    equip = "equip - Equips all tools from backpack",
    unequip = "unequip - Stores tools in backpack",
    stop = "stop - Terminates the orbit script",
    lerp = "lerp [num] - Adjusts transition smoothness",
    help = "help - Toggles the command list menu"
}

local function getPartialMatch(input)
    if not input or input == "" then return nil end
    for _, c in ipairs(cmds) do
        if c:sub(1, #input) == input then return c end
    end
    return nil
end

