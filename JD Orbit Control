                end
                
                if found then
                    currentSuggestionCommand = args[1] .. " " .. found
                    suggestionLabel.Text = args[1] .. " " .. args[2] .. found:sub(#sName + 1)
                    
                    if spaceHit then
                        isUpdating = true
                        cmdInput.Text = currentSuggestionCommand .. " "
                        cmdInput.CursorPosition = #cmdInput.Text + 1
                        suggestionLabel.Text = cmdInput.Text
                        isUpdating = false
                    end
                else
